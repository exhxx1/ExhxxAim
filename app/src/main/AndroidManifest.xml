<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.exhxx78.aim">
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
    <application android:label="Exhxx Aim 🎯" android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <service android:name=".CrosshairService" android:exported="false" />
        <service android:name=".FilterService" android:exported="false" />
        
        <!-- خدمة الماكرو السحرية -->
        <service android:name=".MacroService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data android:name="android.accessibilityservice" android:resource="@xml/macro_config" />
        </service>
    </application>
</manifest>
